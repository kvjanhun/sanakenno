{
  "name": "sanakenno",
  "version": "1.5.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch server/index.ts & pnpm --filter @sanakenno/web dev -- --open",
    "dev:client": "pnpm --filter @sanakenno/web dev",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm --filter @sanakenno/web build",
    "preview": "pnpm --filter @sanakenno/web preview",
    "test:unit": "vitest run",
    "test:bdd": "cucumber-js",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "create-admin": "tsx scripts/archive/create-admin.ts",
    "version:changeset": "changeset",
    "version:bump": "changeset version && node scripts/sync-versions.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@sanakenno/shared": "workspace:*",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.7.4",
    "resend": "^6.10.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "better-sqlite3",
      "esbuild"
    ],
    "patchedDependencies": {
      "react-native-bottom-tabs@1.1.0": "patches/react-native-bottom-tabs@1.1.0.patch"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.50.1",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4",
    "zustand": "^5.0.3"
  }
}
